@page
@model agriloco.api.Pages.Farmer.CropsModel
@{
    ViewData["Title"] = "Farmer Crop Console";
}

<h1>Farmer Crop Console</h1>

<form method="get" class="mb-3">
    <label for="FarmId">Farm ID:</label>
    <input type="number" id="FarmId" name="FarmId" value="@Model.FarmId" />
    <button type="submit">Load Farm</button>
</form>

<h2>Add New Crop</h2>

<form method="post">
    <input type="hidden" asp-for="FarmId" />

    <div>
        <label asp-for="NewCrop.Category">Category (e.g. Apple, Strawberry):</label>
        <input asp-for="NewCrop.Category" />
    </div>

    <div>
        <label asp-for="NewCrop.Variety">Variety (e.g. Honeycrisp, Maya):</label>
        <input asp-for="NewCrop.Variety" />
    </div>

    <div>
        <label asp-for="NewCrop.Availability">Availability (Available / NotAvailable / empty):</label>
        <input asp-for="NewCrop.Availability" />
    </div>

    <div>
        <label asp-for="NewCrop.OfferingType">Offering Type:</label>
        <select asp-for="NewCrop.OfferingType">
            <option value="">(empty)</option>
            <option value="PickYourOwn">PickYourOwn</option>
            <option value="ReadyPicked">ReadyPicked</option>
            <option value="Frozen">Frozen</option>
        </select>
    </div>

    <button type="submit">Add Crop</button>
</form>

<h2>Existing Crops for Farm @Model.FarmId</h2>

@if (Model.ExistingCrops.Any())
{
    <table border="1" cellpadding="4" cellspacing="0">
        <thead>
            <tr>
                <th>Id</th>
                <th>Category</th>
                <th>Variety</th>
                <th>Availability</th>
                <th>OfferingType</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var crop in Model.ExistingCrops)
            {
                <tr>
                    <td>@crop.Id</td>
                    <td>@crop.Category</td>
                    <td>@crop.Variety</td>
                    <td>@crop.Availability</td>
                    <td>@crop.OfferingType</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No crops found for this farm yet.</p>
}