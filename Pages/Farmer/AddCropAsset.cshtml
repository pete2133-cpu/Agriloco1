@page
@model Agriloco.Api.Pages.Farmer.AddCropAssetModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2>Add Crop Asset</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div style="padding:10px; margin:10px 0; border:1px solid #ccc;">
        @Model.Message
    </div>
}

<form method="post" style="max-width:640px;">
    @Html.AntiForgeryToken()

    <div style="margin-bottom:12px;">
        <label><b>Select Farm</b></label><br />
        <select asp-for="Input.FarmId" style="width:100%;">
            <option value="">-- select farm --</option>
            @foreach (var f in Model.Farms)
            {
                <option value="@f.Id">@f.Name (@f.RegionCode)</option>
            }
        </select>
        <span asp-validation-for="Input.FarmId" style="color:red;"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Category</b></label><br />
        <select asp-for="Input.Category" style="width:100%;" onchange="this.form.submit()">
            <option value="">-- select category --</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c">@c</option>
            }
        </select>
        <span asp-validation-for="Input.Category" style="color:red;"></span>
        <div style="font-size:12px; color:#555;">(Selecting category reloads varieties.)</div>
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Variety (optional)</b></label><br />
        <select asp-for="Input.Variety" style="width:100%;">
            <option value="">-- none --</option>
            @foreach (var v in Model.Varieties)
            {
                <option value="@v">@v</option>
            }
        </select>
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Availability (optional)</b></label><br />
        <select asp-for="Input.Availability" style="width:100%;">
            <option value="">-- none --</option>
            <option value="Available">Available</option>
            <option value="NotAvailable">NotAvailable</option>
        </select>
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Year Planted (optional)</b></label><br />
        <input asp-for="Input.YearPlanted" style="width:100%;" />
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Rootstock (optional)</b></label><br />
        <input asp-for="Input.Rootstock" style="width:100%;" />
    </div>

    <div style="margin-bottom:12px;">
        <label><b>Notes (optional)</b></label><br />
        <textarea asp-for="Input.Notes" style="width:100%; height:90px;"></textarea>
    </div>

    <button type="submit" name="submitAction" value="create">Create Crop Asset</button>
</form>

<hr />

@if (Model.CreatedPreview != null)
{
    <h3>Created</h3>
    <pre>@System.Text.Json.JsonSerializer.Serialize(Model.CreatedPreview, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}